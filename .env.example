# Development PostgreSQL database. Copy to .env or set this value in the
# environment before running Prisma migration commands. Do not commit .env.
DATABASE_URL="postgresql://aura_dev:aura_dev@localhost:5432/aura_development?schema=public"

# Required by startup/environment validation (Epic 6 Slice 6M1). The app will
# not report ready via /api/health/ready without these set. Generate a real
# secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="replace-with-a-generated-secret-at-least-32-characters-long"
APP_URL="http://localhost:3000"
