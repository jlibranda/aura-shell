# Development PostgreSQL database. Copy to .env or set this value in the
# environment before running Prisma migration commands. Do not commit .env.
DATABASE_URL="postgresql://aura_dev:aura_dev@localhost:5432/aura_development?schema=public"

# Required by startup/environment validation (Epic 6 Slice 6M1). The app will
# not report ready via /api/health/ready without these set. NEXTAUTH_SECRET is
# also the key used to hash production session tokens before they're stored
# (Epic 6 Slice 6M0.1) — rotating it invalidates every existing session.
# Generate a real secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="replace-with-a-generated-secret-at-least-32-characters-long"
APP_URL="http://localhost:3000"

# One-time production administrator bootstrap (Epic 6 Slice 6M0.1). Not read
# by the app itself — only by `npm run admin:bootstrap`. Never commit real
# values; pass them as one-off environment variables on the command line/CI.
#   BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
#   BOOTSTRAP_ADMIN_PASSWORD=a-real-generated-password
#   BOOTSTRAP_ADMIN_TENANT_ID=your-tenant-id
#   BOOTSTRAP_ADMIN_ROLES=hr_admin        (optional, comma-separated; defaults to hr_admin)
#   BOOTSTRAP_RESET_PASSWORD=true         (optional, to rotate an existing user's password)