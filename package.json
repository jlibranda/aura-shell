{
  "name": "aura-shell",
  "version": "1.0.0",
  "private": true,
  "description": "AURA — Application Shell (Sprint 1 / Epic 1). UI-only enterprise shell.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "seed:development": "set \"AURA_SEED_ENV=development\"&& node scripts/run-development-seed.cjs",
    "outbox:inspect": "node scripts/run-outbox-inspection.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "clsx": "2.1.1",
    "lucide-react": "0.454.0",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.15",
    "postcss": "8.4.47",
    "prisma": "^6.19.0",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
