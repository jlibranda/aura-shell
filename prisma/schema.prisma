generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tenant is the storage isolation root. Trusted request construction—not the
/// browser—selects the tenant used by future repository adapters.
model Tenant {
  id                           String                        @id @map("tenant_id")
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  employees                    Employee[]
  auditRecords                 AuditRecord[]
  submissionIdempotencyRecords SubmissionIdempotencyRecord[]
  outboxMessages               OutboxMessage[]
  tenantMemberships            TenantMembership[]
  sessions                     Session[]
  configurationDefinitions     ConfigurationDefinition[]
  configurationVersions        ConfigurationVersion[]

  @@map("tenants")
}

/// The stable identity of one configurable policy/settings object (Epic 7
/// Slice 7A). scopeType/scopeReference describe *where* this definition
/// applies; only TENANT is populated today since no legal-entity/location/
/// department tables exist yet to attach a real assignment to — the field
/// exists so the resolver contract doesn't have to change shape later.
model ConfigurationDefinition {
  id           String                  @id @default(uuid()) @map("definition_id")
  tenantId     String                  @map("tenant_id")
  type         String                  @map("type")
  code         String                  @map("code")
  name         String                  @map("name")
  description  String?                 @map("description")
  scopeType    String                  @default("TENANT") @map("scope_type")
  scopeRef     String                  @map("scope_ref")
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String                  @map("created_by")
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  versions     ConfigurationVersion[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@map("configuration_definitions")
}

/// One version of a configuration's payload. Published versions are
/// immutable in application code (see ConfigurationUnitOfWork); a
/// correction always creates a new version rather than mutating this row.
/// updatedAt doubles as the optimistic-concurrency token for draft edits.
model ConfigurationVersion {
  id             String                  @id @default(uuid()) @map("version_id")
  definitionId   String                  @map("definition_id")
  tenantId       String                  @map("tenant_id")
  versionNumber  Int                     @map("version_number")
  status         String                  @map("status")
  effectiveFrom  DateTime?               @map("effective_from") @db.Timestamptz(6)
  effectiveUntil DateTime?               @map("effective_until") @db.Timestamptz(6)
  payload        Json                    @map("payload")
  schemaVersion  Int                     @default(1) @map("schema_version")
  changeReason   String?                 @map("change_reason")
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String                  @map("created_by")
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt    DateTime?               @map("published_at") @db.Timestamptz(6)
  publishedBy    String?                 @map("published_by")
  retiredAt      DateTime?               @map("retired_at") @db.Timestamptz(6)
  definition     ConfigurationDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([definitionId, versionNumber])
  @@index([tenantId, definitionId, status])
  @@index([tenantId, definitionId, effectiveFrom])
  @@map("configuration_versions")
}

/// The platform login identity (Epic 6 Slice 6M0.1). Deliberately separate
/// from Employee: Employee is HR record data, not authentication data, and
/// a User is not guaranteed to correspond to an Employee row.
model User {
  id                String             @id @default(uuid()) @map("user_id")
  email             String             @unique @map("email")
  passwordHash      String             @map("password_hash")
  passwordSalt      String             @map("password_salt")
  status            String             @default("active") @map("status")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenantMemberships TenantMembership[]
  sessions          Session[]

  @@map("users")
}

/// Which tenant a User may access, and with which roles. Roles are the same
/// flat PlatformRole[] shape TrustedRequestContext already carries — no
/// separate RoleAssignment table, since roles have no independent lifecycle
/// of their own here (see Slice 6M0.1 architecture analysis).
model TenantMembership {
  id        String   @id @default(uuid()) @map("membership_id")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  roles     String[] @map("roles")
  status    String   @default("active") @map("status")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

/// A server-verified session. The browser cookie carries only the opaque
/// token; tokenHash (not the token) is what's stored, so a database read
/// alone can never produce a usable session. tenantId is the tenant this
/// session was authenticated into — resolved server-side at login from the
/// user's memberships, never taken from the browser.
model Session {
  id        String   @id @default(uuid()) @map("session_id")
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Transactional domain-event delivery record. Payloads are safe event
/// projections; workers never read Employee aggregates through this model.
model OutboxMessage {
  messageId           String    @id @map("message_id")
  eventId             String    @unique @map("event_id")
  tenantId            String    @map("tenant_id")
  eventName           String    @map("event_name")
  aggregateType       String    @map("aggregate_type")
  aggregateId         String    @map("aggregate_id")
  correlationId       String    @map("correlation_id")
  occurredAt          DateTime  @map("occurred_at") @db.Timestamptz(6)
  payload             Json
  state               String
  attempts            Int       @default(0)
  availableAt         DateTime  @map("available_at") @db.Timestamptz(6)
  processedAt         DateTime? @map("processed_at") @db.Timestamptz(6)
  leaseOwner          String?   @map("lease_owner")
  processingStartedAt DateTime? @map("processing_started_at") @db.Timestamptz(6)
  leaseExpiresAt      DateTime? @map("lease_expires_at") @db.Timestamptz(6)
  lastErrorCode       String?   @map("last_error_code")
  lastError           String?   @map("last_error")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([state, availableAt])
  @@index([state, leaseExpiresAt])
  @@index([tenantId, occurredAt])
  @@map("outbox_messages")
}

/// Durable replay protection for internal command submission. It records only
/// a request hash and a sanitized result; no employee personal data is stored.
model SubmissionIdempotencyRecord {
  tenantId       String   @map("tenant_id")
  idempotencyKey String   @map("idempotency_key")
  commandType    String   @map("command_type")
  requestHash    String   @map("request_hash")
  state          String
  result         Json?    @map("result_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([tenantId, idempotencyKey])
  @@map("submission_idempotency_records")
}

/// This is the durable representation of the existing authoritative employee
/// aggregate. Government identifiers, payroll, compensation, tax, and banking
/// data are deliberately not part of this model.
model Employee {
  tenantId              String   @map("tenant_id")
  employeeId            String   @map("employee_id")
  employeeNumber        String   @map("employee_number")
  displayName           String   @map("display_name")
  firstName             String   @map("first_name")
  middleName            String?  @map("middle_name")
  lastName              String   @map("last_name")
  preferredName         String?  @map("preferred_name")
  dateOfBirth           DateTime @map("date_of_birth") @db.Date
  gender                String
  maritalStatus         String   @map("marital_status")
  nationality           String
  workEmail             String   @map("work_email")
  personalEmail         String?  @map("personal_email")
  mobileNumber          String   @map("mobile_number")
  homeAddress           String   @map("home_address")
  departmentId          String   @map("department_id")
  teamId                String?  @map("team_id")
  position              String
  managerId             String?  @map("manager_id")
  employmentType        String   @map("employment_type")
  employmentStatus      String?  @map("employment_status")
  hireDate              DateTime @map("hire_date") @db.Date
  workLocation          String   @map("work_location")
  emergencyContactName  String?  @map("emergency_contact_name")
  emergencyRelationship String?  @map("emergency_relationship")
  emergencyMobileNumber String?  @map("emergency_mobile_number")
  emergencyEmail        String?  @map("emergency_email")
  emergencyAddress      String?  @map("emergency_address")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([tenantId, employeeId])
  @@unique([tenantId, employeeNumber])
  @@unique([tenantId, workEmail])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, departmentId])
  @@map("employees")
}

/// Append-only command outcome evidence. The migration installs a PostgreSQL
/// trigger that rejects UPDATE and DELETE operations on this table.
model AuditRecord {
  auditId       String   @id @map("audit_id")
  occurredAt    DateTime @map("occurred_at") @db.Timestamptz(6)
  tenantId      String   @map("tenant_id")
  actorUserId   String   @map("actor_user_id")
  requestId     String   @map("request_id")
  correlationId String   @map("correlation_id")
  transactionId String   @map("transaction_id")
  commandName   String   @map("command_name")
  eventName     String   @map("event_name")
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  result        String
  metadata      Json
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId, occurredAt])
  @@index([tenantId, aggregateType, aggregateId])
  @@index([correlationId])
  @@map("audit_records")
}
